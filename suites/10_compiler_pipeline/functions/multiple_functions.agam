@lang.advance
// Test: multiple helper functions calling each other.
fn double(x: i64) -> i64 { return x * 2; }
fn triple(x: i64) -> i64 { return x * 3; }
fn add_doubled_tripled(a: i64, b: i64) -> i64 { return double(a) + triple(b); }
fn main() -> i32 { print_int(add_doubled_tripled(5, 3)); return 0; }
