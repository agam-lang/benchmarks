@lang.advance
// Test: if/else chains with complex nesting.
fn classify(n: i64) -> i64 {
    if n < 0 { return -1; }
    if n == 0 { return 0; }
    if n < 10 { return 1; }
    if n < 100 { return 2; }
    return 3;
}
fn main() -> i32 {
    print_int(classify(-5) + classify(0) + classify(7) + classify(50) + classify(200));
    return 0;
}
