@lang.advance
// Test: nested loops with inner/outer interaction.
fn main() -> i32 {
    let total: i64 = 0;
    let i: i64 = 0;
    while i < 10 {
        let j: i64 = 0;
        while j < i {
            total = total + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    print_int(total);
    return 0;
}
